    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nddae3025624942a6b59cda5b6e68d1cd">
        <rdf:value>Gli uomini abito a coda in cappottino,  e tuba in capo.  Le signore, in abito da pomeriggio, e i cappellini con alti nastri, alla moda di un tempo.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
