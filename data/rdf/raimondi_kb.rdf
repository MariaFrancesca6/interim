    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Naf84f09cddd64ba380037a5ca1ec418d">
        <rdf:value>Una carnalità perfino essu- dativa e sudaticcia. Il giovanotto ha lasciato il letto disfatto, per mettersi all'opera di scuoiatore. </rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
