  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/carra/ekphrasis/ek1/anno_0">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/denotation"/>
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/integration"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N53401e380ba642bc803ec675473b504e">
        <rdf:value>Gentiluomo ubriaco</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N77942207ced7448f9097937cacda4e21">
        <rdf:value>"Gentiluomo ubriaco":</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N679148d9dc8b4e09ad2a35edf64d394a">
        <rdf:value>ripensarlo, oggi, così a distanza, mi pare che questa figura, questa testa, e la suggestione e quasi il mistero che vi sortono affondati e irraggiungibili, questo "oggetto" degno di medi- tazione e di lenta osservazione, cosparso alla superfice di qualcosa come una malinconia im- ponderabile, - questo misterioso "Gentiluomo ubriaco", resti nel tempo e nella memoria col peso inevitabile di uno di quei sassi, o massi di sasso, in cui il genio particolare di Costantino Brancusi, lo scultore rumeno, da cui si può dire che incomincia una "nuova scul- tura, ha saputo vedere e rivelare alla luce della vita, una testa, un volto umano, spingendolo, si può dire, fino all'orlo del sorriso</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
