      <oa:TextualBody rdf:nodeID="Nda8dd96a981e4caabe9f27797c086132">
        <rdf:value>Non è traccia di uomo, né di passaggio umano. Tuttavia il quadro è di un'alta, commovente invocazione umana. Così, in una sorta di nuova, ripensata, trasognata, profonda mediatazione plastica del tempo dell' "arte metafisica", </rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
