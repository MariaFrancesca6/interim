    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N7d5ccbac4a934610b9b19f09e8124a09">
        <rdf:value>i fogli affaticati, le carte improvvise e consunte appaiono, col mistero di vere e proprie apparizioni fanaticamente provocate, gli studi di ogni parte del corpo uma- no: e sono gambe e coscie, ventri e ombelichi, fianchi morbidi e natiche magre, e schie- ne e reni, e dorsi fino alle spalle, simile a colline tra valloncelli</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
