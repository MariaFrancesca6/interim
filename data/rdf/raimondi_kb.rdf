  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/giotto/ekphrasis/ek6/anno_0">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/dynamization"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nd46042b3fbd84c1c9b55330f729bea49">
        <rdf:value>Nell’accogliere nel proprio cuore la tristezza e il peso, il mormorio sordo, il vasto confabulare di quelle folle di uomini stipati:</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N455adf9246714eb498c1807de800a148">
        <rdf:value>e imperiali, ma come calavano i barbari dalle valli alpine in pianura, e straripavano nelle conche appenniniche, pestando e sconvolgendo il suolo d’Italia. Parlando, cantando rauche canzoni, alitando il fiato di cibi ignoti, emanando l’odore di vesti e di costumi per noi misteriosi.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
