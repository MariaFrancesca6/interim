  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/toscani/ekphrasis/ek12/anno_0">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/denotation"/>
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/dynamization"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N73c41be77fd34b25ac61e8cd6becb3e8">
        <rdf:value>il Maestro del Chiostro degli aranci, della Badia fiorentina, proveremo di infilare mettere qualche parola.  Sono dodici storie della vita di San Benedetto: qui ne sono venute dieci, di qualità altissima.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nb80d21b8754d4bbebd22393203bd835f">
        <rdf:value>C’è poco da stare allegri nella vita di questo santo: fin da ragazzo, deve aggiustare i guai combinati dalla nutrice. Fatto uomo: spezza con le mani un bicchiere di vino avvelena- to. Salva un frate, moribondo fra le macerie</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasTarget>
      <oa:SpecificResource rdf:nodeID="Ne787dbb19df04a9ea7a19dd5601715dd">
        <oa:hasSource rdf:resource="https://dl.ficlit.unibo.it/iiif/2/19195/canvas/p8"/>
