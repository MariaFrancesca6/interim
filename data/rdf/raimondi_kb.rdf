  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/degas/ekphrasis/ek1/anno_0">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/denotation"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Ne575f1bf0dde4152a330a8cd2ec95c49">
        <rdf:value>Sopra il divanaccio del corridoio, in una scarsa luce, è appeso l'autoritratto del '54: "Degas à la palette".</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N17e54c3ac6684567a3e04d6353140427">
        <rdf:value>Il dipinto, intessuto in una gamma morbida di terre e di ocre, con un poco di grigio e di bianco,</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
