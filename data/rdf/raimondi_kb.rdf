  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/giotto/ekphrasis/ek3/anno_2">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/integration"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N4f78be20081e495aac60c2e8f881c4a4">
        <rdf:value>Insensibili a quel fuoco, a quella porpora dell’oriente, essi dormo- no e sognano la fine del tempo antico, di tanti secoli di favola, incapaci di imma- ginare l’inizio di un tempo della verità e della realtà, fatto per gli uomini, non più per i dei, per i miti.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
