    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N0f653ddd75724383942e654fba5c7485">
        <rdf:value><![CDATA[la “Natura morta”, datata 1920, nella quale sono ripresi, in pittura, gli oggetti del papier- collé <Anfuso?>, e che rappresentano il tema di una favola francese, di <un'apparizione?> poetica, l’uccellino di coccio colorato la fetta di cocomero]]></rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
