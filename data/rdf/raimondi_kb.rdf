    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N57badea1e4f34b19ac13f58963845c4e">
        <rdf:value>la borghe- se, affabile pura vita  di un tempo. Sono figure lievi, quasi inclinate da un vento di bontà. È il ricordo, o il sogno di un'esistenza umana, che non sarà mai la nostra.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
