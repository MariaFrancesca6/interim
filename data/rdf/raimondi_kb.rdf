    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Ne49b51e45204438abbab711d7f1782b3">
        <rdf:value>Piume, satins, pizzi, jabots, collane, trafori, tulles, merletti, cascate di piegoline, ampie distese della veste, scialle e sciarpa, nastri finali:</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
