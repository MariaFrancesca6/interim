    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nc22f80668b314c82b5127eeb171c7a9e">
        <rdf:value>due versioni dell'Apollo che scortica il pastore Marsia. A- pollo è un giovane spogliato, al solito, nel cui corpo particolari anatomici come le anche o il ventre, il groppone, le spalle, sono di una verità leggermente pesante.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
