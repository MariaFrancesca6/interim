    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N73058a912d4d41bca048352a4ff850c0">
        <rdf:value><![CDATA[quelle terribili teste di vecchi rapaci, <???> ravvolti come in logore sciarpe di lana; quelle foreste di teste colme di lungo pelo, che s’affacciano, minacciosi e indomati ancora, nel fondo della Crocifissione, lì vicino,]]></rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
