  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/giotto/ekphrasis/ek1/anno_1">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/integration"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N12f0976a49964e80bfebada65102d53a">
        <rdf:value>cosa sono questi “colori” che sottintendono, più che un muro di calce, il levigato di un metallo tenuto sul fuoco? Il rosso di prugna, il blu delle susine, il rosso delle ciliegie, ma rimmaginati e impiegati, in luogo dello smalto cotto e vertificato, sulla lamina di rame. </rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
