  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/depisisLibri/ekphrasis/ek2/anno_2">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/integration"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N8f2123b0ef63478fbe54b86dc40cf28e">
        <rdf:value>Macchiette umane, simili a coleotteri, a formiche Maschere di Watteau, spolpate, ridotte a larva larva di puro colore; e tutto fuso, impastato dentro una luce fatta di miele impalpabile, con, in cielo, quei bioccoli di turchino, fiocchi di panna, e frantumi di nero: come le briciole di fulig- gine cadute dalla cappa del camino sulla minestra.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
