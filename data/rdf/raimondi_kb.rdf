  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/pollock/ekphrasis/ek3/anno_0">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/denotation"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nc2dc461580bc4055b5b02c30ee813659">
        <rdf:value>Così l'impiego, come strumenti, in  luogo dei pennelli, atavicamente concepiti come prolungamento della mano dell'artista, degli oggetti più disparati: bastoni, cenci, barattoli di latta bucati nel fondo, e da cui colava, come in una maledizione, un colore violento, con cui ricopriva, solcava, imbrattava i suoi cartoni, fogli di  compensato e tele, distesi per terra.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasTarget>
      <oa:SpecificResource rdf:nodeID="Ndccaeec502c74a2bab82c759630480c5">
