    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N3543a2ad6e174b2eb074f1e027d696fa">
        <rdf:value><![CDATA[Ripesca falci nel corso del fiume. E quando è ora di  refettorio, <???> manda un grazioso corvo <???> a beccare un pane avvelenato, che gli avevano offerto preparato i fratelli.]]></rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
