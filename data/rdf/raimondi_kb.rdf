  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/giotto/ekphrasis/ek2/anno_0">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/denotation"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N39f6e09d71f74f368a74e5f181f971a2">
        <rdf:value>Nell’Innocenzo III che approva la Regola,</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N0e1c0bd2be054e279083c774f0e61785">
        <rdf:value><![CDATA[forza, che  dai  manti si spande sui muri, sotto la  forma stellare di stampiglia, mentre i volti, dai lineamenti scavati, tagliati da scalpelli taglienti, e le mitrie di marmo pesantissimo, sono la prova di un’umanità di passioni lente e <immutabili?>]]></rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
