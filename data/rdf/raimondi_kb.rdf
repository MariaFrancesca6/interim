    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nd56f463a96b748728ef0a8b8ea2d1d60">
        <rdf:value>ma non di gesso, di sasso, di marmo, con quella larghezza e pienezza di rosso, segno di</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
