    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N66095fd3e7604e5da848b2bf2960ea89">
        <rdf:value> incombono dentro uno spa- zio, racchiusi nel vano e nella carpenteria della croce, memorabili e immutabili, quasi ritornati solo natura e sentimento, emanando un suono, un’armonia incantata, una voce che ogni generazione può cogliere, finché la materia dura</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
