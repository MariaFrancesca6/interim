    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N6d2d26ac04d9479aae986834aa16db21">
        <rdf:value><![CDATA[Nell’arco: nel fregio dell'arco <???> soprastante l’Incoronazione, sono <???> quelle teste di angeli:  una è di fanciulla,  lo sguardo lievemente solleva- to verso l’alto, la tenera bocca socchiusa]]></rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
