    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N1452d12e39ce4eb58cb6548c98d532a1">
        <rdf:value>come in  un presagio, ed effetto di orribile tempesta umana. Un fondo inindividuato e miserabile, come un cielo di lana sudicia. Tempo, veramente, da fare pau- ra.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
