  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/toscani/ekphrasis/ek5/anno_0">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/denotation"/>
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/dynamization"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N46859d39a4ce49aa9cbf05e34c0ccaa6">
        <rdf:value>È un gruppo, qui, di profeti, staccati dai muri di S. Maria Novella.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N4315cf050d1547eb86f3c773fa8ea33f">
        <rdf:value>Si affacciano, questi personaggi colmi di vita, dal pertugio quadrilobato:</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
