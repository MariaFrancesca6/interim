  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/depisisTorino/ekphrasis/ek5/anno_1">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/denotation"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N75fb378809d542d5be7d27c70b71e3ea">
        <rdf:value>sugli  orizzonti di cielo e di acqua stagnante, ricompaiono, cari cari  fantasmi, le case, le  fattorie rosse, i pali e le reti delle valli sotto il Po  i modelli di primo piano: le conchiglie, le aragoste,</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
