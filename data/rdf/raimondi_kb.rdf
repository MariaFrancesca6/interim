  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/pollock/ekphrasis/ek3/anno_1">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/dynamization"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N197e32f143b843bc964bdb2529c52354">
        <rdf:value>Divenivano pavimenti, tappeti sinistri di poesia, di urlo,  di grido, come espressione della poesia più atroce che il cuore umano d'uomo possa contenere. I colori violen- ti della passione: il giallo, il rosso, il verde, confusi al nero del catrame, dell'asfalto.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
