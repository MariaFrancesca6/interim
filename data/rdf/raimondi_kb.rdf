    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/dynamization"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N2272e596540841318a646f9668c9a207">
        <rdf:value>A fianco del Cristo, i due testimoni: Maria e Giovanni, ravvolti in un ritmo ap- passionato e scandito che nessun teatro, all’infuori di Eschilo, mai ne ebbe di uguali.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
