    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nb164756605224ab48b482ac8c992ecc9">
        <rdf:value><![CDATA[E la sua <???> imperturbabile dolcezza, alquanto ci fa specie. Altro che mitologia! Lo riconosciamo: non è che <???> Giulio, o Giuseppino, il bel garzone del macellaio di via della Mascarella. Il preferito dei modelli]]></rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
