    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N979aafb0ec704569aa3543804b47359a">
        <rdf:value>Quasi una pacifica, monda- na partenza, anzi un ritorno dai bagni al primo fresco di settembre. O come nel finale di una gioiosa, feerica commedia che s’intitoli  per esempio Pene d’amor perduto. </rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
