    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/integration"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N36d23ce383e242df918d81ca48d53ac7">
        <rdf:value>da ideali finestre aperte spalancate  sulla vita di quel tempo fioren- tino.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Ndf47a89a21314da193643b8e4fe954fa">
        <rdf:value>dai cui si gode lo spettacolo bellissimo dell’e- sistenza umana, ognuno col proprio impetuoso pensiero, rivolgendo silenziose, profonde oc- chiate alla platea, dove hanno goduto dei frutti più intensi</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
