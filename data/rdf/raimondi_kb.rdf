  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/toscani/ekphrasis/ek5/anno_3">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/denotation"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N1a56fc04faa84ad0ad1b0daafc6f1dbe">
        <rdf:value>il giovane, pieno il viso pieno, incorniciato da capelli scuri, con la peluria nuova che gli affiora, dolce come la vita, sulle labbra e sulla fossetta del mento. L’altro: dallo sguardo in tralice, incorniciato dal appoggiato al  suo cartiglio sibillino. Con occhi bianchi, vigorosi, di giovane vitello.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
