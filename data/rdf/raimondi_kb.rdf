    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N09ff17162711486d85e6b09d64ea323f">
        <rdf:value>Le due persone dell’annun- ciazione di Botticelli si muovono in una fredda luce verde d'acquario, il cui fondo è di marmi eleganti, tagliati in forme geometriche di geometria.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
