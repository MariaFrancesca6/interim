    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Na89219a161274358a5171b89150785f1">
        <rdf:value>Volti, profili: occhi, bocche, nasi, fronti pietrificati nello spazio, nel momento infinitesimo di quel sentimento per cui furon vivi.  Maschere di un’umanità oggettivata, racchiuse, recinte, prigioniere dentro le sbarre materiali dei nimbi di bronzo, di acciaio</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
