  <lrmoo:F1_Work rdf:about="https://w3id.org/interim/ek-raimondi-kb/carra/ekphrasis/ek20/iconic_ref">
    <rdfs:label>Carlo Carrà, Mattino sul mare, 1928</rdfs:label>
    <owl:sameAs></owl:sameAs>
    <rdfs:seeAlso>https://fototeca.fondazioneragghianti.it/scheda/OA/18792/Carr%C3%A0,%20Carlo,%20Mattino%20sul%20mare</rdfs:seeAlso>
