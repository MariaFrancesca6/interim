  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/ingres/ekphrasis/ek12/anno_5">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/denotation"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nb2cdb57bc0114233b7b1980e021f5f8c">
        <rdf:value> Il capino del del cigno, del boa, si perde in un ciuffo di alghe verdi. Il paesaggio del fondo, nella parete di pianura francese, con la coltre di verdura oltre la riga d'acqua trasparente, il borgo di case bianche, la pieve, il campanile dentro i pini, e la striscia di monti all'orizzonte azzurri</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
