  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/pollock/ekphrasis/ek1/anno_0">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/denotation"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nb28cdb1a3daf4e59a82010fee9e11359">
        <rdf:value> L"ovo" della  mia fissazione, e quasi uscito dalla lunghezza di un pensiero protratto infinitamente, era,  in verità, solo la forma di un volto umano. Era una testa, e un volto, di Raffaello. Do- vevo averlo ricavato da un disegno di Raffaello, visto osservato chissà quando, e non so dove. Una delle sue teste, cosidette di madonne.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasTarget>
      <oa:SpecificResource rdf:nodeID="Nba299ab8040f4201a5e06da4113ca058">
        <oa:hasSource rdf:resource="https://dl.ficlit.unibo.it/iiif/2/19266/canvas/p15"/>
