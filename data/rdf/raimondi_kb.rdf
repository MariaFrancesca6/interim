    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nf888c4efb5a34344837e4f9ab5dc7108">
        <rdf:value>nessuna riunione di  conchiglie è mai stata più felice e dolorosa di questa: involucri fantastici, spoglie durature e bellissime di piccoli esseri che non contano</rdf:value>
