  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/carra/ekphrasis/ek1/anno_2">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/denotation"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N2e438c67c9f64128ac45c0c99c4e7ca4">
        <rdf:value>Alla base del naso, dove il naso si spicca dal volto. Poi, più sotto, dove diremo che è il men- to, dove l'ovoide allungato del capo dovrebbe inserirsi sul collo È qui, come si sa, il collo è invece solo un cilindro, un breve cilindro, ma staccato, tagliato fuori dal soprastante capo</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
