  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/ingres/ekphrasis/ek14/anno_0">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/denotation"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N1d9f2ce3929f4156882d453873ef1d36">
        <rdf:value>il pittore Granet. Il modello gli piacque. Propose di farne un ritratto: il suo primo ritratto romano. Alla figura, spavalda come un Van Dyck (che Ingres non amava),  una veduta di Roma. Forse è la mole stessa di Villa Medici, che sovrasta le case, le finestre, le altane sotto i tetti di Roma. </rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
