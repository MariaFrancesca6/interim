  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/degas/ekphrasis/ek2/anno_1">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/integration"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nc09fc4acd62847ce8e4fd4535cd6dd96">
        <rdf:value>(lo stesso modello con viso di meticcio, di "meridionale" appassionato) in cui traspare, quasi ancor maggiormente che nel "Degas à la palette", se si può dire, il pathos pesante e costipato, tra il volto, l'eleganza lo chic romantico dell'abito</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
