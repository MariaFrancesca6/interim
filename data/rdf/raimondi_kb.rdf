    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N3ca822a21e6948a9b7af563811872d70">
        <rdf:value> giunto ai volti, il pittore svaga e sfugge, quasi terrorizza- to di dover riconoscere e rispettare, di tutto un corpo umano, il punto della coscienza e della personalità: per cui non ferma che lo scavo, più vago e doloroso, degli occhi.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
