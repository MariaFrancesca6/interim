  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/reni/ekphrasis/ek9/anno_0">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/denotation"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N9d6741db0fc44340ace5ecb2c4d862ef">
        <rdf:value>O quello d'Ippomene nella corsa con Atalanta: un oggetto d'a- vorio tiepido, riscaldato col fiato, con quel lembo  di mantello violetto, spuntato, come foglia, nell'orto, sotto le gambe liscie del giovane elfo. </rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
