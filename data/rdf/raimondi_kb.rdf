  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/pollock/ekphrasis/ek4/anno_7">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/dynamization"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N9241c5150a0a425a8a16de29e56fbd30">
        <rdf:value>Tutto il suo corpo riluceva in quell'incanto di carnalità amorosa.</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasTarget>
