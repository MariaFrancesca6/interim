    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Na00e9b3042ae4cc08e48b80d0e54fe66">
        <rdf:value> la forte "posa" della signora Mallet: la miscela "eteroclita" (Baudelaire) vi  é perfetta: la salute della moglie di un "ingeniere di ponti e strade", la giusta venustà, il decoro burocratico della toilette,</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N1d39a88692a34983a5ae830e232a4703">
        <rdf:value>stianità, alla civica registrazione dei palazzi, delle case, delle vetrate, delle finestre e delle tegole sui tetti, </rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
