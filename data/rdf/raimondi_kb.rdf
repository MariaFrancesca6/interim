  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/pontormo/ekphrasis/ek4/anno_1">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/integration"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nc0b62066e1fc453896def7f20d146722">
        <rdf:value>Sono grovigli disperati e un poco mo- struosi, gruppi penosi e un poco repellenti di esseri, che avendo, per una specie di maledizione, perduta ogni qualità umana, sono trasformati nei corpi di fantastici dra- ghi, serpi e ramarri. Proprio una fossa, un vivaio agghiacciante di serpenti con qual- che residuo attributo umano</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
