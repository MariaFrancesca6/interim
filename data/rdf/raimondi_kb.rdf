    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nca2eea7fa549414f9a07406b818e624e">
        <rdf:value><![CDATA[Lady Cavendisch: la duplice fioritura, in grappoli, dei  riccioli di bronzo, posa sulla porcellana di un volto <???> da Frago, mentre le incrostazioni,  porcellana, argento, ristagnano sulle camicettes, nel collo, nelle spalle]]></rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
