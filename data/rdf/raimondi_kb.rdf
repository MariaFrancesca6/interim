  <oa:Annotation rdf:about="https://w3id.org/interim/ek-raimondi-kb/toscani/ekphrasis/ek6/anno_1">
    <geko:hasEkphrasticModality rdf:resource="https://w3id.org/geko/integration"/>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nc4653b0e868a4cf193b7b1c73c18175c">
        <rdf:value><![CDATA[in questo brano di muro dipinto, ostenta la meraviglia di una cultura, insolita per Firenze, votata al gu- sto, all’estetica da una civiltà “cortese” e francesizzante, squisita, rarissima. La Madonna è un il prelibato campione di una tale civiltà mista: figlia orgogliosa <???> di un sangue aristo- critico, gentile,]]></rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="Nc1d2b35b6e4d4fd4821a40f4277eca67">
        <rdf:value>come in un perfetto cerimoniale di corte</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
