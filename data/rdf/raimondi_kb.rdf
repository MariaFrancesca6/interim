    <oa:hasBody>
      <oa:TextualBody rdf:nodeID="N37d59a3dc81240bc9306b8467e0eda54">
        <rdf:value>Poichè il pensiero, e quasi la coscienza di un senso d'amore e di passione amorosa, sono soffusi in ogni parte, e riscaldano di un ca- lore continuo, temperato,</rdf:value>
        <dc:format>text/plain</dc:format>
      </oa:TextualBody>
    </oa:hasBody>
