          "body": {
            "type": "TextualBody",
            "value": "\"Homma- ge à Watteau\". In una larga strada: una periferia, o un sobborgo di piccole case,",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
