          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/denotation",
          "body": {
            "type": "TextualBody",
            "value": "coppie di coniu- gi coi bambini per mano; e due signore da sole, e una ragazzina",
