              }
            },
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19318/canvas/p3",
              "selector": {
                "type": "FragmentSelector",
                "value": "xywh=173,1825,1412,47"
              }
            }
          ],
          "hasAnchor": {
            "type": "Anchor",
            "isAnchoredTo": "http://www.wikidata.org/entity/Q46373"
          },
