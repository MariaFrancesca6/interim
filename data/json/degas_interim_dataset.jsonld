          "body": {
            "type": "TextualBody",
            "value": "Sopra il divanaccio del corridoio, in una scarsa luce, è appeso l'autoritratto del '54: \"Degas à la palette\".",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19318/canvas/p3",
              "selector": {
