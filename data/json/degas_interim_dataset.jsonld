          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/dynamization",
          "body": {
            "type": "TextualBody",
            "value": "Il giovanotto di vent'anni, ben dotato per la pittura, vi si affaccia e dichiara con la serietà, gravità d'impegno che resteranno l'insegna della sua vita",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
