          "id": "http://w3id.org/interim/ek-raimondi-kb/carra/ekphrasis/ek1/anno_1",
          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/integration",
          "body": {
            "type": "TextualBody",
            "value": "questo \"zuccone\" donatelliano del ventesimo secolo. ",
            "format": "text/plain"
          },
          "target": {
            "type": "SpecificResource",
            "source": "https://dl.ficlit.unibo.it/iiif/2/19310/canvas/p6",
            "selector": {
              "type": "FragmentSelector",
