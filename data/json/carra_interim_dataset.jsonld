        {
          "id": "http://w3id.org/interim/ek-raimondi-kb/carra/ekphrasis/ek1/anno_3",
          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/dynamization",
          "body": {
            "type": "TextualBody",
            "value": " le aggiunte di colore andavano a raggiungere l'orecchio, il padiglione dell'orecchio,",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19310/canvas/p6",
              "selector": {
                "type": "FragmentSelector",
                "value": "xywh=195,1364,1414,58"
              }
            },
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19310/canvas/p6",
              "selector": {
                "type": "FragmentSelector",
                "value": "xywh=189,1437,1410,65"
              }
            }
          ],
          "hasAnchor": {
            "type": "Anchor"
          },
          "creator": "Maria Francesca Bocchi",
          "created": "",
          "motivatedBy": "commenting",
          "wasGeneratedBy": {
            "id": "https://w3id.org/interim/ek-raimondi-kb/act/ek1/anno_4",
            "type": "InterpretationAct",
            "hasInterpretationType": "https://w3id.org/interim/ek-raimondi-kb/type/semantic-matching",
            "hasInterpretationCriterion": "https://w3id.org/interim/ek-raimondi-kb/criterion/textual-analysis"
          }
        },
        {
          "id": "http://w3id.org/interim/ek-raimondi-kb/carra/ekphrasis/ek1/anno_4",
          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/denotation",
          "body": {
            "type": "TextualBody",
            "value": "che è l'orecchio sinistro del \"Gentiluomo\", dove questo si attacca, aderisce alla parte cilindrica posteriore della testa.",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19310/canvas/p6",
              "selector": {
                "type": "FragmentSelector",
                "value": "xywh=189,1437,1410,65"
              }
            },
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19310/canvas/p6",
              "selector": {
                "type": "FragmentSelector",
                "value": "xywh=191,1516,1412,60"
              }
            }
          ],
          "hasAnchor": {
            "type": "Anchor"
          },
          "creator": "Maria Francesca Bocchi",
          "created": "",
          "motivatedBy": "commenting",
          "wasGeneratedBy": {
            "id": "https://w3id.org/interim/ek-raimondi-kb/act/ek1/anno_5",
            "type": "InterpretationAct",
            "hasInterpretationType": "https://w3id.org/interim/ek-raimondi-kb/type/semantic-matching",
            "hasInterpretationCriterion": "https://w3id.org/interim/ek-raimondi-kb/criterion/textual-analysis"
          }
        },
        {
          "id": "http://w3id.org/interim/ek-raimondi-kb/carra/ekphrasis/ek1/anno_5",
          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/dynamization",
          "body": {
            "type": "TextualBody",
            "value": "Quel bianco si posava, col peso e la stabilità di un cemento, con la pronta opacità del gesso sul muro. E il di- pinto pareva, veramente, un pezzo, uno spazio di muro su cui il \"maestro\" applicasse i tocchi finali, gli aggiustamenti, riempisse con mano esperta i piccoli invisibili vuoti, spia- nasse e livellasse le impercettibili mancanze, che solo il suo occhio può avvertire Lo Zuccone, la testa-cilindro del signore \"Ubriaco\" si andava così completando, ostruen- do in una pienezza, in un giusto peso e giusta dimensione, che di più non si poteva",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19310/canvas/p6",
              "selector": {
