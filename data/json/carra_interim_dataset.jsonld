      "hasTextualReferent": {
        "id": "http://w3id.org/interim/ek-raimondi-kb/carra/ekphrasis/ek1/textual_ref",
        "type": "F2_Expression",
        "rdfs:label": "Raimondi, Giuseppe. Quaderno manoscritto, \"Storia di Carlo Carra. Gennaio 1961\"",
        "owl:sameAs": ""
      },
      "objectProducedBy": "http://example.org/interim/ekph_relation",
      "items": [
        {
          "id": "http://w3id.org/interim/ek-raimondi-kb/carra/ekphrasis/ek1/anno_0",
          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/integration",
          "body": {
            "type": "TextualBody",
            "value": "ripensarlo, oggi, così a distanza, mi pare che questa figura, questa testa, e la suggestione e quasi il mistero che vi sortono affondati e irraggiungibili, questo \"oggetto\" degno di medi- tazione e di lenta osservazione, cosparso alla superfice di qualcosa come una malinconia im- ponderabile, - questo misterioso \"Gentiluomo ubriaco\", resti nel tempo e nella memoria col peso inevitabile di uno di quei sassi, o massi di sasso, in cui il genio particolare di Costantino Brancusi, lo scultore rumeno, da cui si può dire che incomincia una \"nuova scul- tura, ha saputo vedere e rivelare alla luce della vita, una testa, un volto umano, spingendolo, si può dire, fino all'orlo del sorriso",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19310/canvas/p7",
              "selector": {
