        {
          "id": "http://w3id.org/interim/ek-raimondi-kb/carra/ekphrasis/ek1/anno_2",
          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/denotation",
          "body": {
            "type": "TextualBody",
            "value": "Alla base del naso, dove il naso si spicca dal volto. Poi, più sotto, dove diremo che è il men- to, dove l'ovoide allungato del capo dovrebbe inserirsi sul collo È qui, come si sa, il collo è invece solo un cilindro, un breve cilindro, ma staccato, tagliato fuori dal soprastante capo",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19310/canvas/p6",
