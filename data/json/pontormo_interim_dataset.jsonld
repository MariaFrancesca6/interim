          "hasEkphrasticModality": "https://w3id.org/geko/denotation",
          "body": {
            "type": "TextualBody",
            "value": "i fogli affaticati, le carte improvvise e consunte appaiono, col mistero di vere e proprie apparizioni fanaticamente provocate, gli studi di ogni parte del corpo uma- no: e sono gambe e coscie, ventri e ombelichi, fianchi morbidi e natiche magre, e schie- ne e reni, e dorsi fino alle spalle, simile a colline tra valloncelli",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19386/canvas/p8",
