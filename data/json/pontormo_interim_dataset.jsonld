          "hasEkphrasticModality": "https://w3id.org/geko/denotation",
          "body": {
            "type": "TextualBody",
            "value": "i disegni sorpavissuti degli affreschi di San Lorenzo, e fermarsi a osservare i corpi e i nudi di uomini nelle scene per il Diluvio.",
            "format": "text/plain"
          },
          "target": [
