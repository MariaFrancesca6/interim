        {
          "id": "http://w3id.org/interim/ek-raimondi-kb/pollock/ekphrasis/ek1/anno_0",
          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/denotation",
          "body": {
            "type": "TextualBody",
            "value": " L\"ovo\" della  mia fissazione, e quasi uscito dalla lunghezza di un pensiero protratto infinitamente, era,  in verità, solo la forma di un volto umano. Era una testa, e un volto, di Raffaello. Do- vevo averlo ricavato da un disegno di Raffaello, visto osservato chissà quando, e non so dove. Una delle sue teste, cosidette di madonne.",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19266/canvas/p15",
              "selector": {
                "type": "FragmentSelector",
