      "objectProducedBy": "http://example.org/interim/ekph_relation",
      "items": [
        {
          "id": "http://w3id.org/interim/ek-raimondi-kb/pollock/ekphrasis/ek3/anno_0",
          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/denotation",
          "body": {
            "type": "TextualBody",
            "value": "Così l'impiego, come strumenti, in  luogo dei pennelli, atavicamente concepiti come prolungamento della mano dell'artista, degli oggetti più disparati: bastoni, cenci, barattoli di latta bucati nel fondo, e da cui colava, come in una maledizione, un colore violento, con cui ricopriva, solcava, imbrattava i suoi cartoni, fogli di  compensato e tele, distesi per terra.",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19266/canvas/p17",
              "selector": {
                "type": "FragmentSelector",
                "value": "xywh=138,940,1416,53"
              }
            },
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19266/canvas/p17",
              "selector": {
                "type": "FragmentSelector",
                "value": "xywh=138,1016,1410,53"
              }
            },
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19266/canvas/p17",
              "selector": {
                "type": "FragmentSelector",
                "value": "xywh=142,1094,1386,51"
              }
            },
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19266/canvas/p17",
              "selector": {
                "type": "FragmentSelector",
                "value": "xywh=130,1169,1416,56"
              }
            },
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19266/canvas/p17",
              "selector": {
                "type": "FragmentSelector",
                "value": "xywh=136,1244,1416,54"
              }
            }
          ],
          "hasAnchor": {
            "type": "Anchor"
          },
          "creator": "Maria Francesca Bocchi",
          "created": "",
          "motivatedBy": "commenting",
          "wasGeneratedBy": {
            "id": "https://w3id.org/interim/ek-raimondi-kb/act/ek1/anno_1",
            "type": "InterpretationAct",
            "hasInterpretationType": "https://w3id.org/interim/ek-raimondi-kb/type/semantic-matching",
            "hasInterpretationCriterion": "https://w3id.org/interim/ek-raimondi-kb/criterion/textual-analysis"
          }
        },
        {
          "id": "http://w3id.org/interim/ek-raimondi-kb/pollock/ekphrasis/ek3/anno_1",
          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/dynamization",
          "body": {
            "type": "TextualBody",
            "value": "Divenivano pavimenti, tappeti sinistri di poesia, di urlo,  di grido, come espressione della poesia più atroce che il cuore umano d'uomo possa contenere. I colori violen- ti della passione: il giallo, il rosso, il verde, confusi al nero del catrame, dell'asfalto.",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19266/canvas/p17",
              "selector": {
                "type": "FragmentSelector",
