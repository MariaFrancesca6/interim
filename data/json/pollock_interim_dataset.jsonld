          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/denotation",
          "body": {
            "type": "TextualBody",
            "value": "Senza contare il repertorio iconografico, di fotografie del pittore negli anni del  suo lavoro. Volto, per l'età ancora giovanile, consumato dall'ansia e dall'alcool. ",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19266/canvas/p16",
