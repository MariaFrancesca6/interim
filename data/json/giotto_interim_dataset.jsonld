          "hasEkphrasticModality": "https://w3id.org/geko/dynamization",
          "body": {
            "type": "TextualBody",
            "value": "Nell’accogliere nel proprio cuore la tristezza e il peso, il mormorio sordo, il vasto confabulare di quelle folle di uomini stipati:",
            "format": "text/plain"
          },
