            "type": "TextualBody",
            "value": "Si affacciano, questi personaggi colmi di vita, dal pertugio quadrilobato:",
            "format": "text/plain"
          },
          "target": {
            "type": "SpecificResource",
            "source": "https://dl.ficlit.unibo.it/iiif/2/19195/canvas/p7",
            "selector": {
              "type": "FragmentSelector",
