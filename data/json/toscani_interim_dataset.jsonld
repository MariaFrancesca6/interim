          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/integration",
          "body": {
            "type": "TextualBody",
            "value": "dai cui si gode lo spettacolo bellissimo dell’e- sistenza umana, ognuno col proprio impetuoso pensiero, rivolgendo silenziose, profonde oc- chiate alla platea, dove hanno goduto dei frutti più intensi",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19195/canvas/p7",
              "selector": {
