          }
        },
        {
          "id": "http://w3id.org/interim/ek-raimondi-kb/toscani/ekphrasis/ek5/anno_1",
          "type": "Annotation",
          "hasEkphrasticModality": "https://w3id.org/geko/denotation",
          "body": {
            "type": "TextualBody",
            "value": "finestrelle di un loggione, di un ultimo piano sotto il tetto, ",
            "format": "text/plain"
          },
          "target": [
            {
              "type": "SpecificResource",
              "source": "https://dl.ficlit.unibo.it/iiif/2/19195/canvas/p7",
